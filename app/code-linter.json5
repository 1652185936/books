{
  // ArkTS 静态检查配置（CLAUDE.md §5：严格类型检查、禁止无理由 any）
  "files": [
    "**/*.ets",
    "**/*.ts"
  ],
  "ignore": [
    "**/src/ohosTest/**/*",
    "**/src/test/**/*",
    "**/node_modules/**/*",
    "**/oh_modules/**/*",
    "**/build/**/*"
  ],
  "ruleSet": [
    "plugin:@performance/recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "rules": {
    "@typescript-eslint/no-explicit-any": "error"
  }
}
