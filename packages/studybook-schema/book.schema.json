{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/ai.studybook/book.schema.json",
  "title": "AI StudyBook Book",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "authors",
    "languages",
    "source",
    "defaultChapterId",
    "toc"
  ],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "id": {"type": "string"},
    "title": {"type": "string", "minLength": 1},
    "subtitle": {"type": "string"},
    "authors": {"type": "array", "items": {"type": "string"}},
    "description": {"type": "string"},
    "languages": {"type": "array", "items": {"type": "string"}},
    "cover": {"type": "string"},
    "source": {
      "type": "object",
      "required": ["type", "originalFileName", "pdfPageCount", "isScanned"],
      "properties": {
        "type": {"const": "pdf"},
        "originalFileName": {"type": "string"},
        "pdfPageCount": {"type": "integer", "minimum": 1},
        "isScanned": {"type": "boolean"}
      }
    },
    "defaultChapterId": {"type": "string"},
    "toc": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "order", "kind", "title", "file", "sourcePages"],
        "properties": {
          "id": {"type": "string"},
          "order": {"type": "integer", "minimum": 1},
          "kind": {
            "enum": ["lesson", "review", "appendix", "answer-key", "index"]
          },
          "title": {"type": "string"},
          "titleZh": {"type": "string"},
          "file": {"type": "string", "pattern": "^chapters/.+\\.json$"},
          "sourcePages": {
            "type": "array",
            "items": {"type": "integer", "minimum": 1}
          },
          "estimatedMinutes": {"type": "integer", "minimum": 1}
        }
      }
    }
  }
}

